@page "/hermex/logs"
@{
    ViewData["Title"] = "Logs";
}

<div class="m4d-page">
    <div class="m4d-page__head">
        <div>
            <h1 class="m4d-page__title">Diagnostic logs</h1>
            <p class="m4d-page__subtitle">SMTP protocol events, server lifecycle and storage activity — updated live.</p>
        </div>
        <div class="m4d-page__actions">
            <select class="m4d-select" id="m4d-log-level">
                <option value="0">All levels</option>
                <option value="1">Info and above</option>
                <option value="2">Warnings and above</option>
                <option value="3">Errors only</option>
            </select>
            <button type="button" class="m4d-btn" id="m4d-log-refresh">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15-6.7L21 8" /><path d="M21 3v5h-5" /><path d="M21 12a9 9 0 0 1-15 6.7L3 16" /><path d="M3 21v-5h5" /></svg>
                Refresh
            </button>
            <button type="button" class="m4d-btn m4d-btn--danger" id="m4d-log-clear">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                Clear
            </button>
        </div>
    </div>

    <div class="m4d-card m4d-card--flush">
        <table class="m4d-table" id="m4d-log-table">
            <thead>
                <tr>
                    <th class="m4d-col-time">Time</th>
                    <th class="m4d-col-level">Level</th>
                    <th class="m4d-col-cat">Category</th>
                    <th>Message</th>
                    <th class="m4d-col-session">Session</th>
                </tr>
            </thead>
            <tbody id="m4d-log-body"></tbody>
        </table>
        <div class="m4d-empty" id="m4d-log-empty" hidden>
            <p class="m4d-empty__title">No log entries</p>
            <p class="m4d-empty__hint">Diagnostic events will appear here as the SMTP server runs.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/hermex/assets/js/logs.js"></script>
}
