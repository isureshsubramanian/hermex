@inject Hermex.HermexOptions HermexOptions
@{
    var currentPath = (Context.Request.Path.Value ?? string.Empty).TrimEnd('/').ToLowerInvariant();
    string NavClass(string path) => currentPath == path ? "m4d-nav__link m4d-nav__link--active" : "m4d-nav__link";
    var productTitle = HermexOptions.DashboardTitle;
    var pageTitle = ViewData["Title"] is { } t ? $"{t} · {productTitle}" : productTitle;
    var defaultTheme = HermexOptions.DefaultTheme.ToString().ToLowerInvariant();
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>@pageTitle</title>
    <link rel="stylesheet" href="/hermex/assets/css/hermex.css" />
    <script>
        // Apply the theme before first paint to avoid a flash of the wrong colours.
        (function () {
            try {
                var stored = localStorage.getItem('hermex-theme');
                var theme = stored || '@defaultTheme';
                if (theme === 'system' || !theme) {
                    theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                }
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
</head>
<body>
    <header class="m4d-topbar">
        <div class="m4d-topbar__inner">
            <a class="m4d-brand" href="/hermex" aria-label="@productTitle home">
                <span class="m4d-brand__mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="4" width="20" height="16" rx="3" />
                        <path d="m3 7 9 6 9-6" />
                    </svg>
                </span>
                <span class="m4d-brand__text">
                    <span class="m4d-brand__name">@productTitle</span>
                    <span class="m4d-brand__tag">SMTP Inspector</span>
                </span>
            </a>

            <nav class="m4d-nav" aria-label="Primary">
                <a class="@NavClass("/hermex")" href="/hermex">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 3h-4l-2-3H2" /><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" /></svg>
                    <span>Inbox</span>
                </a>
                <a class="@NavClass("/hermex/logs")" href="/hermex/logs">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h13" /><path d="M8 12h13" /><path d="M8 18h13" /><path d="M3 6h.01" /><path d="M3 12h.01" /><path d="M3 18h.01" /></svg>
                    <span>Logs</span>
                </a>
                <a class="@NavClass("/hermex/settings")" href="/hermex/settings">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                    <span>Settings</span>
                </a>
            </nav>

            <div class="m4d-topbar__actions">
                <span class="m4d-status" id="m4d-server-status" title="SMTP server status">
                    <span class="m4d-status__dot"></span>
                    <span class="m4d-status__label">Connecting…</span>
                </span>
                <button type="button" class="m4d-icon-btn" id="m4d-theme-toggle" aria-label="Toggle theme" title="Toggle light / dark theme">
                    <svg class="m4d-icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
                    <svg class="m4d-icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
                </button>
            </div>
        </div>
    </header>

    <main class="m4d-main">
        @RenderBody()
    </main>

    <div class="m4d-toast" id="m4d-toast" aria-live="polite"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="/hermex/assets/js/hermex.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
